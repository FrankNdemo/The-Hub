DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_TIME_ZONE=Africa/Nairobi
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:8080
DB_CONN_MAX_AGE=0

# Vercel production example
# DJANGO_DEBUG=False
# DJANGO_TIME_ZONE=Africa/Nairobi
# DJANGO_ALLOWED_HOSTS=.vercel.app,your-backend-project.vercel.app
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-project.vercel.app
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend-project.vercel.app
# FRONTEND_BASE_URL=https://your-frontend-project.vercel.app
# Keep this at 0 for serverless deployments and Supabase pooler connections.
# DB_CONN_MAX_AGE=0

# Email delivery
# Local development default:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=The Wellness Hub <no-reply@wellnesshub.local>
SERVER_EMAIL=The Wellness Hub <no-reply@wellnesshub.local>
WELLNESS_HUB_REPLY_TO=hello@wellnesshub.local
BOOKING_DURATION_MINUTES=60
BOOKING_OPEN_HOUR=10
BOOKING_CLOSE_HOUR=19
BOOKING_SLOT_INTERVAL_MINUTES=5
BOOKING_REMINDER_LEAD_MINUTES=60
BOOKING_CALENDAR_UID_DOMAIN=wellnesshub.local
BOOKING_CALENDAR_ORGANIZER_NAME=The Wellness Hub
VIRTUAL_SESSION_BASE_URL=https://meet.jit.si
VIRTUAL_SESSION_ROOM_PREFIX=the-wellness-hub
CRON_SECRET=replace-with-a-long-random-secret

# For production with Brevo, DEFAULT_FROM_EMAIL should be a sender identity verified in Brevo.

# Brevo SMTP example
# Use your SMTP login and SMTP key from Brevo. Do not use the HTTP API key here.
# Official Brevo SMTP relay docs:
# https://help.brevo.com/hc/en-us/articles/7924908994450-Send-transactional-emails-using-Brevo-SMTP
# https://developers.brevo.com/docs/smtp-integration
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=False
# EMAIL_TIMEOUT=30
# EMAIL_HOST_USER=your-brevo-smtp-login
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key

# Brevo API alternative
# BREVO_API_KEY=your-brevo-api-key
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email
# BREVO_API_TIMEOUT=30

# Local SQLite is the default. Switch to PostgreSQL/Supabase later by changing the engine and fields below.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_SSLMODE=

# Optional: use a full Supabase/Postgres connection string instead of the fields above.
# Raw special characters in the password are supported, but `DB_*` variables are also fine on Vercel.
# If you use the Supabase transaction pooler on port 6543, use the pooler username from Supabase
# and keep sslmode=require.
# Example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Alternative Supabase alias variables. The backend accepts these too.
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=
SUPABASE_DB_SSLMODE=
